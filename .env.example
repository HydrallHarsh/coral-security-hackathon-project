# Copy this file to .env and fill in local values.
# Do not commit .env.

# Keep HarborGuard's Coral sources and credentials isolated from other projects.
CORAL_CONFIG_DIR=%TEMP%\coral-harborguard

# Use "coral" if Coral is installed globally and available on PATH.
# If you keep a local binary, use a path such as .\coral\coral.exe from the directory where you run commands.
CORAL_BIN=coral

# Required only when adding or querying the bundled GitHub source.
# You can use: gh auth token
GITHUB_TOKEN=

# Required only when adding or querying the bundled Slack source.
SLACK_TOKEN=

# Required only when adding or querying the bundled Notion source.
NOTION_API_KEY=
