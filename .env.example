# Copy this file to .env and fill in local values.
# Do not commit .env.

# Keep HarborGuard's Coral sources and credentials isolated from other projects.
CORAL_CONFIG_DIR=%TEMP%\coral-harborguard

# Use "coral" if Coral is installed globally and available on PATH.
# If you keep a local binary, use a path such as .\coral\coral.exe from the directory where you run commands.
CORAL_BIN=coral

# Required only when adding or querying the bundled GitHub source.
# You can use: gh auth token
GITHUB_TOKEN=

# Required only when adding or querying the bundled Slack source.
SLACK_TOKEN=

# Required only when adding or querying the bundled Notion source.
NOTION_API_KEY=

# Agent orchestration.
# Use "true" to let an OpenRouter-hosted LLM choose investigation tools.
# If disabled or if the LLM call fails, HarborGuard falls back to the deterministic planner.
HARBORGUARD_USE_LLM_PLANNER=false
OPENROUTER_API_KEY=

# Pick an OpenRouter model you have access to. Free models often end in ":free".
# Example: qwen/qwen3-235b-a22b:free
OPENROUTER_MODEL=

# Discovery backend.
# "sql" uses Coral metadata tables directly.
# "mcp" starts `coral mcp-stdio` and uses MCP catalog discovery, with SQL metadata fallback.
HARBORGUARD_DISCOVERY_BACKEND=sql
